<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.UiccBrowser" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>

    <style name="Theme.UiccBrowser.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.UiccBrowser.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.UiccBrowser.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style
        name="Widget.UiccBrowser.BinaryKeyboardButton"
        parent="Widget.Material3.Button">
        <item name="android:elevation">0dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:minHeight">@dimen/binary_keyboard_button_min_height</item>
        <item name="android:paddingStart">@dimen/binary_keyboard_button_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/binary_keyboard_button_padding_vertical</item>
        <item name="android:paddingEnd">@dimen/binary_keyboard_button_padding_horizontal</item>
        <item name="android:paddingBottom">@dimen/binary_keyboard_button_padding_vertical</item>
        <item name="android:singleLine">true</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textSize">@dimen/binary_keyboard_text_size</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>
